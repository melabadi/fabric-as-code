# =============================================================================
# Fabric-as-Code — environment template
# -----------------------------------------------------------------------------
# Copy this file to ".env" and fill in the values for your tenant / subscription.
# ".env" is git-ignored and MUST NEVER be committed to a public repository.
#
#   cp .env.example .env        (bash)
#   Copy-Item .env.example .env (PowerShell)
# =============================================================================

# ---- Azure context -----------------------------------------------------------
# The Entra ID (Azure AD) tenant that owns the subscription and Fabric capacity.
TENANT_ID="00000000-0000-0000-0000-000000000000"

# The Azure subscription where the Microsoft.Fabric capacity will be created.
SUBSCRIPTION_ID="00000000-0000-0000-0000-000000000000"

# Resource group + region for the Fabric capacity.
RESOURCE_GROUP="rg-fabric-as-code"
LOCATION="westeurope"

# ---- Fabric capacity ---------------------------------------------------------
# Capacity name must be globally unique, 3-63 chars, lowercase letters/numbers.
CAPACITY_NAME="fabasccapacity01"

# Fabric SKU. F2 is the smallest / cheapest, good for demos. F64+ unlocks
# Copilot and Power BI Pro-equivalent features. Scale up/down anytime.
CAPACITY_SKU="F2"

# Capacity administrators. Comma-separated list of UPNs (users) and/or
# service principal object IDs that can administer the capacity.
CAPACITY_ADMINS="admin@contoso.com"

# ---- Fabric workspace --------------------------------------------------------
WORKSPACE_NAME="Fabric-as-Code Demo"
WORKSPACE_DESCRIPTION="Workspace provisioned end-to-end by the fabric-as-code repo."

# ---- Item names (created inside the workspace) -------------------------------
LAKEHOUSE_NAME="lh_demo"
WAREHOUSE_NAME="wh_demo"
NOTEBOOK_NAME="nb_demo_load"
PIPELINE_NAME="pl_demo_ingest"

# ---- Service principal (recommended for CI/CD & cross-tenant repeats) ---------
# Leave blank to use interactive "az login" / your current user instead.
# When set, scripts authenticate non-interactively with the client secret.
SP_CLIENT_ID=""
SP_CLIENT_SECRET=""
